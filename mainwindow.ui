              <property name="alternatingRowColors"><bool>true</bool></property>
              <property name="showGrid"><bool>true</bool></property>
              <property name="styleSheet">
               <string>
                QTableView {
                  border: 1px solid #dde3ea;
                  font-size: 13px;
                  color: #111111;
                  background-color: white;
                  gridline-color: #eaecef;
                }
                QTableView::item { color: #111111; background-color: white; }
                QTableView::item:alternate { background-color: #f4f6f8; }
                QTableView::item:selected { background-color: #d6eaf8; color: #1e2a3a; }
                QHeaderView::section {
                  background-color: #1e2a3a;
                  color: white;
                  padding: 8px;
                  font-size: 12px;
                  font-weight: bold;
                  border: none;
                }

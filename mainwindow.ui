         <!-- FORM PANEL -->
         <item>
          <widget class="QWidget" name="formPanel">
           <property name="minimumWidth"><number>300</number></property>
           <property name="maximumWidth"><number>340</number></property>
           <!-- Explicit white bg + black text for ALL children to override inheritance -->
           <property name="styleSheet">
            <string>
             QWidget#formPanel { background-color: white; border-radius: 8px; }
             QLabel  { color: #444444; font-size: 12px; background: transparent; }
             QLineEdit {
               background-color: white;
               color: #111111;
               border: 1px solid #cccccc;
               border-radius: 4px;
               padding: 6px 8px;
               font-size: 13px;
             }
             QLineEdit:focus { border: 1px solid #2980b9; }
             QDateEdit {
               background-color: white;
               color: #111111;
               border: 1px solid #cccccc;
               border-radius: 4px;
               padding: 6px 8px;
               font-size: 13px;
             }
             QDateEdit:focus { border: 1px solid #2980b9; }
             QDateEdit::drop-down { border: none; }
            </string>
           </property>
           <layout class="QVBoxLayout" name="formPanelLayout">
            <property name="leftMargin"><number>20</number></property>
            <property name="topMargin"><number>20</number></property>
            <property name="rightMargin"><number>20</number></property>
